<?xml version='1.0'?>

<robot name="QCar" xmlns:xacro="http://www.ros.org/wiki/xacro">

    <xacro:include filename="$(find qcar_updated)/urdf/materials.xacro" />

    <link name="base">
        <visual>
            <origin rpy="0 0 0" xyz="0 0 0" />
            <geometry>
                <mesh filename="package://qcar_updated/models/qcar/QCarBody.stl"
                    scale="0.001 0.001 0.001" />
            </geometry>
            <material name="white" />
        </visual>
        <collision>
            <origin rpy="0 0 0" xyz="0 0 0" />
            <geometry>
                <mesh filename="package://qcar_updated/models/qcar/QCarBody.stl"
                    scale="0.001 0.001 0.001" />
            </geometry>
        </collision>
        <inertial>
            <origin rpy="0 0 0" xyz="0 0 0" />
            <mass value="2.4" />
            <inertia ixx="0.009543" ixy="0" ixz="0" iyy="0.038083" iyz="0" izz="0.038274" />
        </inertial>
    </link>
    <joint name="body_lidar_joint" type="fixed">
        <parent link="base"/>
        <child link="lidar"/>
        <origin rpy="0 0 0" xyz="-0.01227 -0.00045 0.16152"/>
        <axis xyz="0 0 1"/>
    </joint>
    <link name="lidar">
        <visual>
            <origin rpy="0 0 0" xyz="0 0 0" />
            <geometry>
                <mesh filename="package://qcar_updated/models/qcar/QCarLidar.stl"
                    scale="0.001 0.001 0.001" />
            </geometry>
            <material name="blue" />
        </visual>
        <collision>
            <origin rpy="0 0 0" xyz="0 0 0" />
            <geometry>
                <mesh filename="package://qcar_updated/models/qcar/QCarLidar.stl"
                    scale="0.001 0.001 0.001" />
            </geometry>
        </collision>
        <inertial>
            <origin rpy="0 0 0" xyz="0 0 0" />
            <mass value="0.15" />
            <inertia ixx="0.0000724" ixy="0" ixz="0" iyy="0.0000724" iyz="0" izz="0.000133" />
        </inertial>
    </link>
    <joint name="base_hubfl_joint" type="revolute">
        <parent link="base" />
        <child link="hubfl" />
        <origin rpy="0 0 0" xyz="0.12960 0.05590 0.03338" />
        <axis xyz="0 0 1" />
        <dynamics damping="0.143" friction="0.0" />
        <limit lower="-0.5236" upper="0.5236" effort="300" velocity="2" />
    </joint>
    <link name="hubfl">
        <visual>
            <origin rpy="0 0 0" xyz="0 0 0" />
            <geometry>
                <mesh filename="package://qcar_updated/models/qcar/QCarSteeringHubL.stl"
                    scale="0.001 0.001 0.001" />
            </geometry>
            <material name="orange" />
        </visual>
        <collision>
            <origin rpy="0 0 0" xyz="0 0 0" />
            <geometry>
                <mesh filename="package://qcar_updated/models/qcar/QCarSteeringHubL.stl"
                    scale="0.001 0.001 0.001" />
            </geometry>
        </collision>
        <inertial>
            <origin rpy="0 0 0" xyz="0 0 0" />
            <mass value="0.05" />
            <inertia ixx="0.00000925" ixy="0" ixz="0" iyy="0.0000131" iyz="0" izz="0.00000843" />
        </inertial>
    </link>
    <joint name="base_hubfr_joint" type="revolute">
        <parent link="base" />
        <child link="hubfr" />
        <origin rpy="0 0 0" xyz="0.12960 -0.05590 0.03338" />
        <axis xyz="0 0 1" />
        <limit lower="-0.5236" upper="0.5236" effort="300" velocity="2" />
        <dynamics damping="0.143" friction="0.0" />
    </joint>
    <link name="hubfr">
        <visual>
            <origin rpy="0 0 0" xyz="0 0 0" />
            <geometry>
                <mesh filename="package://qcar_updated/models/qcar/QCarSteeringHubR.stl"
                    scale="0.001 0.001 0.001" />
            </geometry>
            <material name="orange" />
        </visual>
        <collision>
            <origin rpy="0 0 0" xyz="0 0 0" />
            <geometry>
                <mesh filename="package://qcar_updated/models/qcar/QCarSteeringHubR.stl"
                    scale="0.001 0.001 0.001" />
            </geometry>
        </collision>
        <inertial>
            <origin rpy="0 0 0" xyz="0 0 0" />
            <mass value="0.05" />
            <inertia ixx="0.00000925" ixy="0" ixz="0" iyy="0.0000131" iyz="0" izz="0.00000843" />
        </inertial>
    </link>
    <joint name="hubfl_wheelfl_joint" type="continuous">
        <parent link="hubfl" />
        <child link="wheelfl" />
        <origin rpy="0 0 3.14" xyz="0 0 0" />
        <axis xyz="0 1 0" />
    </joint>
    <link name="wheelfl">
        <visual>
            <origin rpy="0 0 0" xyz="0 0 0" />
            <geometry>
                <mesh filename="package://qcar_updated/models/qcar/QCarWheel.stl"
                    scale="0.001 0.001 0.001" />
            </geometry>
            <material name="red" />
        </visual>
        <collision>
            <origin rpy="0 0 0" xyz="0 0 0" />
            <geometry>
                <mesh filename="package://qcar_updated/models/qcar/QCarWheel.stl"
                    scale="0.001 0.001 0.001" />
            </geometry>
        </collision>
        <inertial>
            <origin rpy="0 0 0" xyz="0 0 0" />
            <mass value="0.2" />
            <inertia ixx="0.0000645" ixy="0" ixz="0" iyy="0.0001089" iyz="0" izz="0.0000645" />
        </inertial>
    </link>
    <joint name="hubfr_wheelfr_joint" type="continuous">
        <parent link="hubfr" />
        <child link="wheelfr" />
        <origin rpy="0 0 0" xyz="0 0 0" />
        <axis xyz="0 1 0" />
    </joint>
    <link name="wheelfr">
        <visual>
            <origin rpy="0 0 0" xyz="0 0 0" />
            <geometry>
                <mesh filename="package://qcar_updated/models/qcar/QCarWheel.stl"
                    scale="0.001 0.001 0.001" />
            </geometry>
            <material name="orange" />
        </visual>
        <collision>
            <origin rpy="0 0 0" xyz="0 0 0" />
            <geometry>
                <mesh filename="package://qcar_updated/models/qcar/QCarWheel.stl"
                    scale="0.001 0.001 0.001" />
            </geometry>
        </collision>
        <inertial>
            <origin rpy="0 0 0" xyz="0 0 0" />
            <mass value="0.2" />
            <inertia ixx="0.0000645" ixy="0" ixz="0" iyy="0.0001089" iyz="0" izz="0.0000645" />
        </inertial>
    </link>

    <joint name="base_wheelrl_joint" type="continuous">
        <parent link="base" />
        <child link="wheelrl" />
        <origin rpy="0 0 3.14" xyz="-0.12765 0.05610 0.03338" />
        <axis xyz="0 1 0" />
    </joint>
    <link name="wheelrl">
        <visual>
            <origin rpy="0 0 0" xyz="0 0 0" />
            <geometry>
                <mesh filename="package://qcar_updated/models/qcar/QCarWheel.stl"
                    scale="0.001 0.001 0.001" />
            </geometry>
            <material name="orange" />
        </visual>
        <collision>
            <origin rpy="0 0 0" xyz="0 0 0" />
            <geometry>
                <mesh filename="package://qcar_updated/models/qcar/QCarWheel.stl"
                    scale="0.001 0.001 0.001" />
            </geometry>
        </collision>
        <inertial>
            <origin rpy="0 0 0" xyz="0 0 0" />
            <mass value="0.2" />
            <inertia ixx="0.0000645" ixy="0" ixz="0" iyy="0.0001089" iyz="0" izz="0.0000645" />
        </inertial>
    </link>

    <joint name="base_wheelrr_joint" type="continuous">
        <parent link="base" />
        <child link="wheelrr" />
        <origin rpy="0 0 0" xyz="-0.12765 -0.05610 0.03338" />
        <axis xyz="0 1 0" />
    </joint>
    <link name="wheelrr">
        <visual>
            <origin rpy="0 0 0" xyz="0 0 0" />
            <geometry>
                <mesh filename="package://qcar_updated/models/qcar/QCarWheel.stl"
                    scale="0.001 0.001 0.001" />
            </geometry>
            <material name="red" />
        </visual>
        <collision>
            <origin rpy="0 0 0" xyz="0 0 0" />
            <geometry>
                <mesh filename="package://qcar_updated/models/qcar/QCarWheel.stl"
                    scale="0.001 0.001 0.001" />
            </geometry>
        </collision>
        <inertial>
            <origin rpy="0 0 0" xyz="0 0 0" />
            <mass value="0.2" />
            <inertia ixx="0.0000645" ixy="0" ixz="0" iyy="0.0001089" iyz="0" izz="0.0000645" />
        </inertial>
    </link>

    <joint name="camera_rgb_joint" type="fixed">
        <!-- <axis xyz="0 1 0" /> -->
        <!-- <origin xyz=".2 0 0" rpy="0 0 0"/> -->
        <origin rpy="0 0 0" xyz="0.081686 0 0.15445" />
        <!-- <origin rpy="0 0 0" xyz="0 0 0"/> -->
        <parent link="base" />
        <child link="camera_rgb" />
    </joint>
    <link name="camera_rgb" />

    <joint name="camera_csi_front_joint" type="fixed">
        <!-- <axis xyz="0 1 0" /> -->
        <!-- <origin xyz=".2 0 0" rpy="0 0 0"/> -->
        <origin rpy="0 0 0" xyz="0.19236 -0.000475 0.093029" />
        <!-- <origin rpy="0 0 0" xyz="0 0 0"/> -->
        <parent link="base" />
        <child link="camera_csi_front" />
    </joint>
    <link name="camera_csi_front" />

    <joint name="camera_csi_right_joint" type="fixed">
        <!-- <axis xyz="0 1 0" /> -->
        <!-- <origin xyz=".2 0 0" rpy="0 0 0"/> -->
        <origin rpy="0 0 -1.5708" xyz="0.12887 -0.06755 0.093029" />
        <!-- <origin rpy="0 0 0" xyz="0 0 0"/> -->
        <parent link="base" />
        <child link="camera_csi_right" />
    </joint>
    <link name="camera_csi_right" />

    <joint name="camera_csi_back_joint" type="fixed">
        <!-- <axis xyz="0 1 0" /> -->
        <!-- <origin xyz=".2 0 0" rpy="0 0 0"/> -->
        <origin rpy="0 0 -3.1416" xyz="-0.16669 -0.000578 0.093029" />
        <!-- <origin rpy="0 0 0" xyz="0 0 0"/> -->
        <parent link="base" />
        <child link="camera_csi_back" />
    </joint>
    <link name="camera_csi_back" />

    <joint name="camera_csi_left_joint" type="fixed">
        <!-- <axis xyz="0 1 0" /> -->
        <!-- <origin xyz=".2 0 0" rpy="0 0 0"/> -->
        <origin rpy="0 0 1.5708" xyz="0.12784 0.052497 0.093029" />
        <!-- <origin rpy="0 0 0" xyz="0 0 0"/> -->
        <parent link="base" />
        <child link="camera_csi_left" />
    </joint>
    <link name="camera_csi_left" />

    <gazebo reference="camera_csi_front">
        <sensor type="camera" name="front_camera">
            <update_rate>30.0</update_rate>
            <camera name="head">
                <horizontal_fov>2</horizontal_fov>
                <image>
                    <width>640</width>
                    <height>480</height>
                    <format>R8G8B8</format>
                </image>
            </camera>
            <plugin name="camera_controller" filename="libgazebo_ros_camera.so">
                <cameraName>qcar/csi_front</cameraName>
            </plugin>
        </sensor>
    </gazebo>

    <gazebo>
        <plugin name="gazebo_ros2_control" filename="libgazebo_ros2_control.so">
            <parameters>$(find qcar_updated)/config/qcar_controllers.yaml</parameters>
        </plugin>
    </gazebo>

    <!-- LiDAR Sensor -->
    <gazebo reference="lidar">
        <sensor type="ray" name="lidar_sensor">
            <pose>0 0 0 0 0 0</pose>
            <visualize>true</visualize>
            <update_rate>10</update_rate>
            <ray>
                <scan>
                    <horizontal>
                        <samples>360</samples>
                        <resolution>1</resolution>
                        <min_angle>-3.14159</min_angle>
                        <max_angle>3.14159</max_angle>
                    </horizontal>
                </scan>
                <range>
                    <min>0.15</min>
                    <max>12.0</max>
                    <resolution>0.01</resolution>
                </range>
                <noise>
                    <type>gaussian</type>
                    <mean>0.0</mean>
                    <stddev>0.01</stddev>
                </noise>
            </ray>
            <plugin name="lidar_controller" filename="libgazebo_ros_ray_sensor.so">
                <ros>
                    <remapping>~/out:=/scan</remapping>
                </ros>
                <output_type>sensor_msgs/LaserScan</output_type>
                <frame_name>lidar</frame_name>
            </plugin>
        </sensor>
    </gazebo>

    <!-- Ground truth odometry from Gazebo physics -->
    <gazebo>
        <plugin name="gazebo_ros_p3d" filename="libgazebo_ros_p3d.so">
            <ros>
                <remapping>odom:=/odom</remapping>
            </ros>
            <body_name>base</body_name>
            <frame_name>world</frame_name>
            <update_rate>30</update_rate>
            <xyz_offset>0 0 0</xyz_offset>
            <rpy_offset>0 0 0</rpy_offset>
            <gaussian_noise>0.01</gaussian_noise>
        </plugin>
    </gazebo>

    <ros2_control name="qcar" type="system">
        <hardware>
            <plugin>gazebo_ros2_control/GazeboSystem</plugin>
        </hardware>

        <joint name="base_hubfl_joint">
            <command_interface name="position" />
            <state_interface name="position" />
            <state_interface name="velocity" />
        </joint>

        <joint name="base_hubfr_joint">
            <command_interface name="position" />
            <state_interface name="position" />
            <state_interface name="velocity" />
        </joint>

        <joint name="base_wheelrl_joint">
            <command_interface name="velocity" />
            <state_interface name="position" />
            <state_interface name="velocity" />
        </joint>

        <joint name="base_wheelrr_joint">
            <command_interface name="velocity" />
            <state_interface name="position" />
            <state_interface name="velocity" />
        </joint>
    </ros2_control>

</robot>
  